.trip-dates {
    /* Placeholder — styles to be developed with the design */
}

.trip-dates__inner {
    /* inherits content-width-sm layout */
}

.trip-dates__heading {
    /* Section heading: "Dates & book" */

    margin: 0 0 space(32);
    text-transform: unset;
}

.trip-dates__list {
    list-style: none;
    margin: 0;
    padding: 0;
}

.trip-dates__item {
    display: flex;
    align-items: center;
    gap: space(16);
    padding: spaceFluid(16, 24);
    padding-block: space(12);
    border: 1px solid var(--color-orange);
    background-color: var(--color-neutral);

    & + & {
        margin-top: space(12);
    }

    &:first-child {
        border-top: 1px solid var(--color-orange);
    }

    /* &.is-sold-out {
        opacity: 0.6;
    } */
}

.trip-dates__item__meta {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: space(8);

    @media (min-width: theme('screens.sm')) {
        flex-direction: row;
        align-items: center;
        gap: space(16);
    }
}

.trip-dates__item__label {
    @apply type-h6;

    margin: 0;
    opacity: 0.9;
}

.trip-dates__item__nights {
    font-size: 0.875em;
    margin-inline-start: 0.5em;
    opacity: 0.6;
}

.trip-dates__item__price {
    font-weight: 600;
}

.trip-dates__item__actions {
    display: flex;
    flex-direction: column;
    gap: space(12);
    align-items: stretch;
    flex-shrink: 0;

    @media (min-width: theme('screens.sm')) {
        flex-direction: row;
        align-items: center;
    }
}

.trip-dates__item__cta {
    white-space: nowrap;

    &:not(.btn--theme-2):not(.trip-dates__item__cta--sold-out) {
        --btn--background-color: var(--color-orange);
        --btn--border-color: var(--color-orange);
        --btn--color: var(--color-navy);
        --btn--background-color--hover: var(--color-mid-blue);
        --btn--border-color--hover: var(--color-mid-blue);
    }
}

.trip-dates__item__cta--sold-out, .trip-dates__item__cta--private {
    --btn--background-color: var(--color-navy);
    --btn--border-color: var(--color-navy);
    --btn--color: rgb(from var(--color-white) r g b / 0.4);
    --btn--background-color--hover: var(--color-navy);
    --btn--border-color--hover: var(--color-navy);
    --btn--color-hover: var(--btn--color);

    white-space: nowrap;
    cursor: default;
    opacity: 1;
}

.trip-dates__empty {
    font-style: italic;
    opacity: 0.6;
}
