{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 2,
    "name": "acf/testimonial-cards",
    "title": "Testimonial Cards",
    "description": "A grid of testimonials with star ratings and author attribution. Source from custom content or selected stories.",
    "category": "theme-blocks",
    "icon": "format-quote",
    "acf": {
        "mode": "auto",
        "renderCallback": "Gust\\Components\\TestimonialCards::renderBlock"
    },
    "supports": {
        "anchor": true,
        "align": ["wide", "full"],
        "color": {
            "text": false,
            "gradients": false,
            "background": false
        }
    }
}
