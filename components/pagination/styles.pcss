.pagination {
    --flow-space: var(--space-base);
    --section--margin-bottom: var(--space-base);
}

.nav-links {
    --pagination--size: 2.1875rem; /* 35px */
    --grid--column-gap: space(8);

    @apply flex-grid;
    @apply flex-grid-auto;

    align-items: center;
    justify-content: center;

    @media (min-width: theme('screens.md')) {
        --pagination--size: 2.1875rem; /* 35px */
    }

    > a,
    > .current {
        --btn--background-color: var(--color-white);
        --btn--border-color: var(--color-white);
        --btn--color: var(--color-foreground);

        --btn--background-color--hover: var(--color-navy);
        --btn--border-color--hover: var(--color-navy);
        --btn--color-hover: var(--color-white);

        --btn--size: var(--pagination--size);

        @apply btn;
        @apply btn--square;
        @apply type-h5;

        box-shadow: var(--base--shadow);
        font-size: 0.875rem; /* 14px */

        &:hover,
        &:focus-visible {
            box-shadow: var(--base--shadow--hover);
        }
    }

    .current {
        --btn--background-color: var(--color-navy);
        --btn--border-color: var(--color-navy);
        --btn--color: var(--color-white);

        --btn--background-color--hover: var(--color-white);
        --btn--border-color--hover: var(--color-navy);
        --btn--color-hover: var(--color-foreground);
    }

    .dots {
        display: inline-flex;
        min-width: var(--pagination--size);
        min-height: var(--pagination--size);
        align-items: center;
        justify-content: center;
    }

    .next,
    .prev {

        @apply btn--icon;
        @apply btn--square;
        
        --btn--background-color: var(--color-background);
        --btn--border-color: var(--color-navy);
        --btn--color: var(--color-navy);

        --btn--background-color--hover: var(--color-navy);
        --btn--border-color--hover: var(--color-navy);
        --btn--color-hover: var(--color-white);

        @apply btn--icon;
        @apply btn--square;

        display: inline-block;

        &::after {
            @apply mask-icon;

            inset: 0;
            margin: auto;
            width: 9px;
            height: 9px;
            mask-image: url('/images/icons/chevron-right.svg');
        }
    }

    .prev {
        &::after {
            transform: rotate(180deg);
        }
    }
}

.nav-links > .page-numbers {
    border-radius: unset;
    border: solid 0.5px var(--color-navy);
}

.nav-links > .page-numbers:hover {
    color: var(--color-white) !important;
}