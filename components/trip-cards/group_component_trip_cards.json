            "name": "selected",
            "type": "relationship",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_trip_cards_card_source",
                        "operator": "==",
                        "value": "selected"
                    }
                ]
            ],
            "post_type": ["trip"],
            "filters": ["search"],
            "min": "1",
            "max": "6",
            "return_format": "object"
