@import 'swiper/css' layer(vendor);

.cards {
    --grid--column-gap: spaceFluid(12, 16);
    --grid--row-gap: var(--grid--column-gap);
    --cards--min-width: 14.375rem; /* 230px */

    :where(.cards__header) {
        @apply margin-trim;

        margin-bottom: var(--section--header--margin-bottom);
        text-align: center;
    }

    :where(.cards__heading) {
        max-width: var(--heading--max-width);
        margin-inline: auto;
        text-align: left;
    }

    :where(.cards__subheading) {
        @apply margin-trim;
        @apply heading-attributes;

        margin: var(--space-base) auto;
        text-align: left;
        color: var(--color-mid-blue);
        font-size: rfs(32, 44);
        line-height: 1;
        letter-spacing: -0.5px;
        text-transform: uppercase;

        & > * {
            font-size: inherit;
            line-height: inherit;
            letter-spacing: inherit;
            font-weight: inherit;
        }
    }

    :where(.cards__items) {
        @apply flex-grid;
        

        justify-content: center;
    }

    &:where(.cards--source--custom):not([class*='cards--columns-']) {
        .cards__items {
            @apply card-grid-square;

            justify-content: normal;
        }

        .g-card {
            width: 100%;
            max-width: none;
        }
    }

    &:where(.cards--taxonomy-term-grid) {
        .cards__items {
            display: grid;
            grid-template-columns: 1fr;
            justify-content: normal;

            @media (min-width: theme('screens.md')) {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            @media (min-width: theme('screens.lg')) {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
        }

        .g-card {
            width: 100%;
            max-width: none;
        }
    }

    :where(.cards__footer) {
        @apply margin-trim;

        margin-top: var(--section--footer--margin-top);
    }

    :where(.cards__more-link) {
        justify-self: center;
        text-align: center;
    }

    &:not(.alignfull) {
        overflow: var(--rounded-overflow, visible);
    }

    &.alignfull {
        .cards__inner {
            @apply content-width-fluid-lg;
        }
    }

    &.has-background {
        .cards__inner {
            padding-top: var(--section--padding-y);
            padding-bottom: var(--section--padding-y);
        }

        &:not(.alignfull) {
            padding-right: var(--section--padding-x);
            padding-left: var(--section--padding-x);
        }
    }

    &[class*='cards--columns-'] {
        .cards__items {
            display: grid;
            grid-template-columns: repeat(var(--grid--columns), minmax(0, 1fr));
            justify-content: normal;
            margin-bottom: var(--section--header--margin-bottom);
        }

        .g-card {
            width: 100%;
            max-width: none;
        }
    }

    &:where(.cards--columns-4) {
        @media (min-width: theme('screens.md')) {
            --grid--columns: 2;
        }

        @media (min-width: theme('screens.xl')) {
            --grid--columns: 4;
        }
    }

    &:where(.cards--columns-3) {
        @media (min-width: theme('screens.md')) {
            --grid--columns: 3;
        }
    }

    &:where(.cards--columns-2) {
        @media (min-width: theme('screens.md')) {
            --grid--columns: 2;
        }

        .cards__inner {
            @apply content-width-md;
        }
    }

    &:where(.cards--columns-1) {
        --grid--columns: 1;

        .cards__inner {
            @apply content-width-md;
        }
    }

    &:where(.cards--slider-on-mobile) {
        @media (max-width: 1023px) {
            --animate--translateY: 0;

            .cards__items {
                position: relative !important;
                display: flex !important;
                flex-wrap: nowrap !important;
                justify-content: flex-start !important;
                grid-template-columns: unset !important;
                padding-bottom: space(8);
                margin-right: calc(-1 * var(--container-padding));
                margin-bottom: calc(space(8) * -1);
                margin-left: calc(-1 * var(--container-padding));
                column-gap: 0;
                overflow-x: auto !important;
                scroll-snap-type: x mandatory;
                will-change: transform;

                &::before,
                &::after {
                    display: block;
                    overflow: hidden;
                    height: 1px;
                    flex: 0 0 var(--container-padding);
                    content: '';
                    opacity: 0;
                    pointer-events: none;
                }
            }

            .g-card {
                min-width: var(--cards--min-width);
                min-height: 100%;
                flex: 0 0 80%;
                margin-top: 0;
                margin-right: var(--grid--column-gap);
                scroll-snap-align: center;

                @media (min-width: theme('screens.sm')) {
                    flex-basis: 37%;
                }

                &:last-child {
                    margin-right: 0;
                }
            }
        }
    }

    &:where(.cards--type--horizontal) {
        .cards__items {
            display: grid;
            grid-template-columns: 1fr;
            justify-content: normal;

            @media (min-width: theme('screens.md')) {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        .g-card {
            width: 100%;
            max-width: none;
        }
    }

    &.cards--type--carousel {
        --cards--carousel--btn-size: 45px;
        --cards--carousel--gap: 24px;
        --cards--carousel--slides: 1.2;
        --cards--carousel--nav-top: calc(
            ((100cqw - ((var(--cards--carousel--slides) - 1) * var(--cards--carousel--gap))) / var(--cards--carousel--slides)) / 2
        );

        @media (min-width: theme('screens.md')) {
            --cards--carousel--slides: 2;
        }

        @media (min-width: theme('screens.lg')) {
            --cards--carousel--slides: 3;
        }

        &:where(.cards--columns-1) {
            @media (min-width: theme('screens.md')) {
                --cards--carousel--slides: 1;
            }
        }

        &:where(.cards--columns-2) {
            @media (min-width: theme('screens.lg')) {
                --cards--carousel--slides: 2;
            }
        }

        &:where(.cards--columns-4) {
            @media (min-width: theme('screens.lg')) {
                --cards--carousel--slides: 4;
            }
        }

        display: block;

        .cards__swiper-wrap {
            position: relative;
            container-type: inline-size;
        }

        .cards__swiper {
            overflow: clip;
            width: 100%;
        }

        .cards__items {
            display: flex;
            flex-wrap: nowrap;
            grid-template-columns: none;
            justify-content: flex-start;
            gap: 0;
        }

        .cards__slide {
            height: auto;
            display: flex;
            flex-shrink: 0;
        }

        .g-card {
            width: 100%;
            max-width: none;
            height: 100%;
        }

        .cards__prev,
        .cards__next {
            position: absolute;
            top: var(--cards--carousel--nav-top);
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
            width: var(--cards--carousel--btn-size);
            height: var(--cards--carousel--btn-size);
            padding: 0;
            border: 1px solid var(--color-navy);
            border-radius: 0;
            background: var(--color-white);
            color: var(--color-navy);
            cursor: pointer;
            transform: translateY(-50%);
            transition: opacity 0.2s;

            &:hover {
                opacity: 0.6;
            }

            &.swiper-button-disabled {
                opacity: 0.3;
                cursor: not-allowed;
            }
        }

        .cards__prev {
            left: max(
                calc(var(--cards--carousel--btn-size) / -2),
                calc(var(--container-padding) * -1)
            );

            .btn__icon {
                rotate: 180deg;
            }
        }

        .cards__next {
            right: max(
                calc(var(--cards--carousel--btn-size) / -2),
                calc(var(--container-padding) * -1)
            );
        }
    }
}
